# Flyfish open-source deployment example.
# Copy this file to your deployment platform or shell environment and fill real values there.

# Runtime profile and ports
SPRING_PROFILES_ACTIVE=prod
FLYFISH_LOWCODE_PORT=10081
FLYFISH_SHOP_PORT=10082

# Database
SPRING_R2DBC_URL=r2dbc:mysql://127.0.0.1:3306/flyfish_dev
SPRING_R2DBC_USERNAME=flyfish
SPRING_R2DBC_PASSWORD=

# Shared auth
USER_JWT_SECRET=
OAUTH_CALLBACK_URL=https://example.com/oauth/callback
OAUTH_GITEA_CLIENT_ID=
OAUTH_GITEA_CLIENT_SECRET=
OAUTH_GITEE_CLIENT_ID=
OAUTH_GITEE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Email magic link and notification mail
EMAIL_MAGIC_LINK_BASE_URL=https://example.com
EMAIL_MAGIC_LINK_FROM=
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true

# WeChat official account
WX_MP_APP_ID=
WX_MP_SECRET=
WX_MP_TOKEN=
WX_MP_AES_KEY=
WX_MP_CUSTOMER_SERVICE_MEDIA_ID=
WX_MP_QUICK_LOGIN_BASE_URL=https://example.com

# Payment
H5ZHIFU_API_BASE_URL=https://open.h5zhifu.com/api
H5ZHIFU_APP_ID=
H5ZHIFU_KEY=
H5ZHIFU_NOTIFY_URL=https://example.com/shops/payments/h5zhifu/notify
H5ZHIFU_DEFAULT_PAY_TYPE=wechat
H5ZHIFU_DEFAULT_TRADE_TYPE=native

# Support notification
SUPPORT_NOTIFICATION_ENABLED=true
SUPPORT_NOTIFICATION_PORTAL_BASE_URL=https://example.com
SUPPORT_NOTIFICATION_MAIL_ENABLED=true
SUPPORT_NOTIFICATION_MAIL_FROM=
SUPPORT_NOTIFICATION_MAIL_ADMIN_RECIPIENTS=
SUPPORT_NOTIFICATION_WECHAT_ENABLED=false
SUPPORT_NOTIFICATION_WECHAT_ADMIN_OPENIDS=

# Low-code generator datasource
FLYFISH_GENERATOR_CACHE_PATH=./.cache/generator
GENERATOR_AUTHOR=flyfish
GENERATOR_R2DBC_URL=r2dbc:mysql://127.0.0.1:3306/flyfish_dev
GENERATOR_R2DBC_USERNAME=root
GENERATOR_R2DBC_PASSWORD=
GENERATOR_PACKAGE_PARENT=group.flyfish.generated
